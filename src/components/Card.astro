---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import { SITE } from "@/config";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ogImage: initOgImage, ...props } = data;

const postPath = getPath(id, filePath);

// Resolve thumbnail URL — manual ogImage > dynamic OG image > none
let thumbUrl: string | undefined;
if (typeof initOgImage === "string") {
  thumbUrl = initOgImage;
} else if (initOgImage && typeof initOgImage === "object" && "src" in initOgImage) {
  thumbUrl = (initOgImage as { src: string }).src;
} else if (SITE.dynamicOgImage) {
  thumbUrl = `${postPath}/index.png`;
}
---

<li class="my-6">
  <a
    href={postPath}
    class="group flex flex-col gap-3 sm:flex-row sm:gap-4 sm:items-start"
  >
    {thumbUrl && (
      <img
        src={thumbUrl}
        alt=""
        class="w-full h-40 sm:w-48 sm:h-28 object-cover rounded border border-border flex-shrink-0"
        loading="lazy"
      />
    )}
    <div class="flex-1 min-w-0">
      <Heading
        class:list={[
          "inline-block text-lg font-medium text-accent",
          "decoration-dashed underline-offset-4 group-hover:underline",
        ]}
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
      >
        {title}
      </Heading>
      <Datetime {...props} />
      <p class="mt-1">{description}</p>
    </div>
  </a>
</li>
